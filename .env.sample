# ============================================================
# UniFi → AutoTask Alert Bridge — Environment Variable Sample
# ============================================================
# Copy this file to .env for local testing (never commit .env).
# In production, set each variable as a Datto RMM Site Variable.
# ============================================================

# ── UniFi Cloud Controller ──────────────────────────────────

# Base URL of the UniFi Cloud Controller (no trailing slash)
# Classic controller:  https://192.168.1.1:8443
# UniFi OS (UDM/Pro):  https://192.168.1.1
UNIFI_BASE_URL=https://unifi.example.com:8443

# UniFi API key — bypasses 2FA. Generate in the controller UI:
# Settings → System → Advanced → API Keys → Create API Key
# Requires UniFi Network Application 8.1+
UNIFI_API_KEY=your-unifi-api-key-here

# Optional: comma-separated list of site DESCRIPTIONS (display names) to poll.
# Leave blank to poll ALL sites visible to the authenticated user.
# Example: AFF001_A1 Taxis,BCC002_B2 Garage
UNIFI_SITE_FILTER=

# ── AutoTask REST API ───────────────────────────────────────

# AutoTask REST API base URL — check your zone in the AutoTask URL bar.
# Common zones: webservices1, webservices2, webservices3, webservices4, webservices5
AT_BASE_URL=https://webservices2.autotask.net/ATServicesRest

# AutoTask API integration user email address
AT_USERNAME=api-integration@yourdomain.com

# AutoTask API secret key (treat as a password — mark as secret in Datto RMM)
AT_SECRET=your-autotask-secret-key-here

# AutoTask Queue ID for new tickets
# Find this in AutoTask: Admin → Service Desk → Queues
AT_QUEUE_ID=29682933

# AutoTask Ticket Source ID
# Find this in AutoTask: Admin → Service Desk → Ticket Sources
AT_SOURCE_ID=4

# AutoTask Default Priority ID for new tickets
# Find this in AutoTask: Admin → Service Desk → Priority
AT_PRIORITY_ID=1

# ── Deduplication Log ───────────────────────────────────────

# Full path to the JSON file used to track which alerts have already
# had tickets created. Must be on a persistent disk (not a temp folder).
# The folder will be created automatically if it does not exist.
DEDUP_LOG_PATH=C:\ProgramData\DattoRMM\UniFiAlerts\dedup.json
